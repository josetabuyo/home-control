# ── Enchufe Smart Life (Tuya) ─────────────────────────────────────────────────
PLUG_IP=192.168.1.XXX
PLUG_DEVICE_ID=         # ID del dispositivo (ver instrucciones abajo)
PLUG_LOCAL_KEY=         # Clave local (ver instrucciones abajo)
PLUG_VERSION=3.3        # Versión del protocolo: 3.1, 3.3, 3.4 o 3.5
PLUG_NAME=Smart Plug    # Nombre personalizado para el dispositivo

# ── Luz A60 RGBCW Smart Life (Tuya) ───────────────────────────────────────────
LIGHT_IP=192.168.1.XXX
LIGHT_DEVICE_ID=
LIGHT_LOCAL_KEY=
LIGHT_VERSION=3.3
LIGHT_NAME=A60 RGBCW    # Nombre personalizado para el dispositivo

# ── Cámara VisionONE (app v720) ────────────────────────────────────────────────
CAMERA_IP=192.168.1.XXX
CAMERA_USER=admin
CAMERA_PASS=

# ────────────────────────────────────────────────────────────────────────────────
# CÓMO OBTENER DEVICE_ID y LOCAL_KEY
# ────────────────────────────────────────────────────────────────────────────────
# 1. Creá una cuenta gratuita en https://iot.tuya.com (Tuya IoT Platform)
# 2. Creá un proyecto → Cloud → Development → Create Cloud Project
# 3. En "Devices" vinculá tu cuenta Smart Life con "Link Tuya App Account"
# 4. Ejecutá:  source .venv/bin/activate && python3 -m tinytuya wizard
#    → va a escanear la red y descargar device_id y local_key automáticamente
#    → guarda los datos en tinytuya.json
# ────────────────────────────────────────────────────────────────────────────────
